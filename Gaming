#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <time.h>

void jogo_perguntas();
void jogo_cobra();
void jogo_gousmas();

void limpar_buffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}
int ler_int(int min, int max) {
    int val;
    while (1) {
        if (scanf("%d", &val) == 1 && val >= min && val <= max) {
            limpar_buffer();
            return val;
        }
        limpar_buffer();
        printf("Invalido, digite um numero entre %d e %d: ", min, max);
    }
}
char ler_alternativa() {
    char c;
    while (1) {
        if (scanf(" %c", &c) == 1) {
            limpar_buffer();
            if (c >= 'A' && c <= 'D') c = c + ('a' - 'A');
            if (c == 'a' || c == 'b' || c == 'c' || c == 'd') return c;
        } else {
            limpar_buffer();
        }
        printf("Alternativa invalida. Digite a, b, c ou d: ");
    }
}
int menu_jogar_novamente() {
    printf("\nDeseja jogar novamente?\n");
    printf("1 - Sim\n");
    printf("2 - Nao (voltar ao menu principal)\n");
    printf("Sua opcao: ");
    return ler_int(1, 2);
}
void jogo_perguntas() {
    int jogar_novamente = 1;
    
    printf("\nPerguntas e respota\n");
    
    while (jogar_novamente == 1) {
        int acertos = 0;
        char resp;
        const char *enunciados[5] = {
            "1) Qual e a raiz cubica de 27?",
            "2) Qual e a raiz quadrada de 2500?",
            "3) Qual e o seno de 30 graus?",
            "4) Quanto e 12 ao quadrado?",
            "5) Qual e a raiz quadrada de 81?"
        };
        const char *alternativas[5][4] = {
            {"a) 4", "b) 3", "c) 2", "d) 5"},
            {"a) 40", "b) 50", "c) 60", "d) 30"},
            {"a) 1", "b) 0,5", "c) 0", "d) 2"},
            {"a) 121", "b) 144", "c) 169", "d) 196"},
            {"a) 8", "b) 9", "c) 10", "d) 7"}
        };
        const char corretas[5] = {'b', 'b', 'b', 'b', 'b'};
        const char *respostas_certas[5] = {
            "b) 3",
            "b) 50",
            "b) 0,5",
            "b) 144",
            "b) 9"
        };
        int i;
        for (i = 0; i < 5; i++) {
            printf("\n%s\n", enunciados[i]);
            printf("%s\n%s\n%s\n%s\n", alternativas[i][0], alternativas[i][1],
                                        alternativas[i][2], alternativas[i][3]);
            printf("Sua resposta: ");
            resp = ler_alternativa();
            if (resp == corretas[i]) {
                printf("Voce acertou\n");
                acertos++;
            } else {
                printf("Voce errou, e a letra: %s\n", respostas_certas[i]);
            }
        }
        printf("\nVoce acertou %d de 5.\n", acertos);
 
        jogar_novamente = menu_jogar_novamente();
    }
}
void jogo_cobra() {
    const char *nomes[7] = {
        "Ana", "Bruno", "Carlos",
        "Diana", "Eduardo", "Fernanda", "Gabriel"
    };
    printf("\n          COBRA NA CAIXA!\n\n");
    printf("Voces estao presos em uma tumba egipcia!\n");
    printf("Ha 5 caixas: uma tem o botao para sair,\n");
    printf("outra esconde uma cobra mortal...\n");
 
    int idx_p1, idx_p2;
    int i;
 
    printf("\nJogador 1, escolha seu nome:\n");
    for (i = 0; i < 7; i++) printf("%d) %s\n", i + 1, nomes[i]);
    printf("Sua escolha: ");
    idx_p1 = ler_int(1, 7) - 1;
    printf("\nJogador 2, escolha seu nome:\n");
    for (i = 0; i < 7; i++) printf("%d) %s\n", i + 1, nomes[i]);
    printf("Sua escolha: ");
    idx_p2 = ler_int(1, 7) - 1;
    while (idx_p2 == idx_p1) {
        printf("O nome ja foi escolhido, escolha outro de (1-7): ");
        idx_p2 = ler_int(1, 7) - 1;
    }
    const char *nome_p1 = nomes[idx_p1];
    const char *nome_p2 = nomes[idx_p2];
    printf("\nJogadores: %s e %s\n", nome_p1, nome_p2);
 
    int jogar_novamente = 1;
 
    while (jogar_novamente == 1) {
        int caixas[5]  = {0, 0, 0, 0, 0};
        int abertas[5] = {0, 0, 0, 0, 0};
        int caixas_restantes = 5;
 
        int pos_botao = rand() % 5;
        int pos_cobra;
        do { pos_cobra = rand() % 5; } while (pos_cobra == pos_botao);
        caixas[pos_botao] = 1;
        caixas[pos_cobra] = 2;
 
        int turno = rand() % 2;
        printf("\nSorteio: %s comeca\n", turno == 0 ? nome_p1 : nome_p2);
 
        int game_over = 0;
 
        while (!game_over) {
            const char *jogador_atual = (turno == 0) ? nome_p1 : nome_p2;
 
            printf("\n--- Turno de %s ---\n", jogador_atual);
            printf("Caixas: ");
            for (i = 0; i < 5; i++) {
                if (abertas[i])
                    printf("[%d:aberta] ", i + 1);
                else
                    printf("[%d] ", i + 1);
            }
            printf("\n");
   
            int escolha;
            printf("Escolha uma caixa (1-5): ");
            escolha = ler_int(1, 5) - 1;
            while (abertas[escolha]) {
                printf("Essa caixa ja foi aberta, escolha outra (1-5): ");
                escolha = ler_int(1, 5) - 1;
            }
            abertas[escolha] = 1;
            caixas_restantes--;
 
            if (caixas[escolha] == 1) {
                printf("\n%s abriu a caixa %d e encontrou o botao!\n", jogador_atual, escolha + 1);
                printf("%s venceu\n", jogador_atual);
                game_over = 1;
            } else if (caixas[escolha] == 2) {
                printf("\nSSSSSS! %s abriu a caixa %d e encontrou a cobra!\n", jogador_atual, escolha + 1);
                printf("%s perdeu\n", jogador_atual);
                game_over = 1;
            } else {
                printf("Caixa %d vazia. Vez do outro jogador.\n", escolha + 1);
                turno = 1 - turno; /* troca turno */
            }
        }
        jogar_novamente = menu_jogar_novamente();
    }
}
typedef struct {
    int furia;
    int destruida;
} Gousma;
void verificar_destruicao(Gousma g[2], const char *nome_jogador) {
    int i;
    for (i = 0; i < 2; i++) {
        if (!g[i].destruida && g[i].furia > 5) {
            g[i].destruida = 1;
            g[i].furia = 0;
            printf("[!] Gousma %c de %s foi destruida! (furia > 5)\n",
                   'A' + i, nome_jogador);
        }
    }
}
int todas_destruidas(Gousma g[2]) {
    return g[0].destruida && g[1].destruida;
}
void mostrar_estado_gousmas(Gousma p1[2], Gousma p2[2]) {
    printf("\n+---------------------------------------+\n");
    printf("| Jogador 1:  Gousma A [Furia: %d%s]  Gousma B [Furia: %d%s]\n",
           p1[0].furia, p1[0].destruida ? " DESTRUIDA]" : "]         ",
           p1[1].furia, p1[1].destruida ? " DESTRUIDA]" : "]         ");
    printf("| Jogador 2:  Gousma A [Furia: %d%s]  Gousma B [Furia: %d%s]\n",
           p2[0].furia, p2[0].destruida ? " DESTRUIDA]" : "]         ",
           p2[1].furia, p2[1].destruida ? " DESTRUIDA]" : "]         ");
    printf("+---------------------------------------+\n");
}
void jogo_gousmas() {
    printf("\n           GOUSMAS WAR\n\n");
    printf("Jogo de estrategia para 2 jogadores.\n\n");
    printf("REGRAS:\n");
    printf(" - Cada jogador tem 2 Gousmas com furia 1.\n");
    printf(" - ATACAR: sua Gousma soma sua furia na\n");
    printf("   furia de uma Gousma inimiga.\n");
    printf(" - DIVIDIR: transfere furia entre suas\n");
    printf("   Gousmas (pode reviver a destruida).\n");
    printf(" - Furia > 5 = Gousma destruida!\n");
    printf(" - Perde quem ficar sem Gousmas ativas.\n");
    printf("========================================\n");
 
    int jogar_novamente = 1;
 
    while (jogar_novamente == 1) {
        Gousma p1[2] = {{1, 0}, {1, 0}};
        Gousma p2[2] = {{1, 0}, {1, 0}};
        const char *nomes_jogadores[2] = {"Jogador 1", "Jogador 2"};
 
        int turno = 0;
        int game_over = 0;
 
        while (!game_over) {
            mostrar_estado_gousmas(p1, p2);
 
            Gousma *meu     = (turno == 0) ? p1 : p2;
            Gousma *inimigo = (turno == 0) ? p2 : p1;
            const char *nome_meu     = nomes_jogadores[turno];
            const char *nome_inimigo = nomes_jogadores[1 - turno];
 
            printf("\nTurno de %s\n", nome_meu);
 
            if (todas_destruidas(meu)) {
                printf("%s nao tem Gousmas ativas! %s VENCEU!\n", nome_meu, nome_inimigo);
                game_over = 1;
                break;
            }
            printf("Escolha uma acao:\n");
            printf("1 - Atacar\n");
            printf("2 - Dividir\n");
            printf("Sua opcao: ");
            int acao = ler_int(1, 2);
 
            if (acao == 1) {
                if (todas_destruidas(inimigo)) {
                    printf("Inimigo nao tem Gousmas ativas! %s VENCEU!\n", nome_meu);
                    game_over = 1;
                    break;
                }
                int atac;
                printf("Escolha sua Gousma atacante (1=A, 2=B): ");
                atac = ler_int(1, 2) - 1;
                while (meu[atac].destruida) {
                    printf("Gousma %c esta destruida! Escolha outra (1=A, 2=B): ", 'A' + atac);
                    atac = ler_int(1, 2) - 1;
                }
                int alvo;
                printf("Escolha a Gousma alvo do inimigo (1=A, 2=B): ");
                alvo = ler_int(1, 2) - 1;
                while (inimigo[alvo].destruida) {
                    printf("Gousma %c do inimigo esta destruida! Escolha outra (1=A, 2=B): ", 'A' + alvo);
                    alvo = ler_int(1, 2) - 1;
                }
                int furia_ataque = meu[atac].furia;
                inimigo[alvo].furia += furia_ataque;
 
                printf("\nGousma %c de %s ataca Gousma %c de %s!\n",
                       'A' + atac, nome_meu, 'A' + alvo, nome_inimigo);
                printf("Gousma %c de %s agora tem furia %d.\n",
                       'A' + alvo, nome_inimigo, inimigo[alvo].furia);
 
                verificar_destruicao(inimigo, nome_inimigo);
                verificar_destruicao(meu, nome_meu);
            } else {
                int doadora;
                printf("Escolha sua Gousma doadora de furia (1=A, 2=B): ");
                doadora = ler_int(1, 2) - 1;
                while (meu[doadora].destruida) {
                    printf("Gousma %c esta destruida! Escolha outra ativa (1=A, 2=B): ", 'A' + doadora);
                    doadora = ler_int(1, 2) - 1;
                }
                int receptora = 1 - doadora;
 
                int max_transferir = meu[doadora].furia - 1;
                if (max_transferir < 1) {
                    printf("Gousma %c tem furia 1, nao pode transferir (ficaria com 0)!\n",
                           'A' + doadora);
                    printf("Acao cancelada. Turno perdido.\n");
                    turno = 1 - turno;
                    continue;
                }
                printf("Gousma %c tem furia %d. Maximo a transferir: %d\n",
                       'A' + doadora, meu[doadora].furia, max_transferir);
                printf("Quantidade de furia a transferir para Gousma %c (1 a %d): ",
                       'A' + receptora, max_transferir);
                int qtd = ler_int(1, max_transferir);
 
                meu[doadora].furia -= qtd;
 
                if (meu[receptora].destruida) {
                    meu[receptora].destruida = 0;
                    meu[receptora].furia = 0;
                    printf("Gousma %c de %s foi revivida!\n", 'A' + receptora, nome_meu);
                }
                meu[receptora].furia += qtd;
 
                printf("Transferido %d ponto(s) de furia.\n", qtd);
                printf("Gousma %c: furia %d | Gousma %c: furia %d\n",
                       'A' + doadora, meu[doadora].furia,
                       'A' + receptora, meu[receptora].furia);
 
                verificar_destruicao(meu, nome_meu);
                verificar_destruicao(inimigo, nome_inimigo);
            }
            if (todas_destruidas(inimigo)) {
                mostrar_estado_gousmas(p1, p2);
                printf("\n>>> %s nao tem mais Gousmas ativas!\n", nome_inimigo);
                printf(">>> %s VENCEU! Parabens!\n", nome_meu);
                game_over = 1;
            } else if (todas_destruidas(meu)) {
                mostrar_estado_gousmas(p1, p2);
                printf("\n>>> %s nao tem mais Gousmas ativas!\n", nome_meu);
                printf(">>> %s VENCEU! Parabens!\n", nome_inimigo);
                game_over = 1;
            } else {
                turno = 1 - turno;
            }
        }
        jogar_novamente = menu_jogar_novamente();
    }
}
int main() {
    srand((unsigned int)time(NULL));
 
    int opcao;
 
    do {
        printf("\nMinigames\n\n");
        printf("1) Pergunta e resposta\n");
        printf("2) Cobra na caixa\n");
        printf("3) Gousmas war\n");
        printf("4) Sair\n");
        printf("\nEscolha uma opcao: ");
        opcao = ler_int(1, 4);
 
        switch (opcao) {
            case 1:
                jogo_perguntas();
                break;
            case 2:
                jogo_cobra();
                break;
            case 3:
                jogo_gousmas();
                break;
            case 4:
                printf("\nObrigado por jogar\n");
                break;
            default:
                printf("Opcao invalida!\n");
        }
    } while (opcao != 4);
    return 0;
}
